{
  "providers": {
    "openai": {
      "api_key_env": "OPENAI_API_KEY",
      "base_url": "https://api.openai.com/v1",
      "base_url_env": "OPENAI_BASE_URL"
    }
  },
  "models": {
    "gpt-5-mini": {
      "provider": "openai",
      "model": "gpt-5-mini",
      "omit_temperature": true
    },
    "gpt-4o-mini": {
      "provider": "openai",
      "model": "gpt-4o-mini"
    },
    "gpt-4.1-mini": {
      "provider": "openai",
      "model": "gpt-4.1-mini"
    }
  },
  "request_options": {
    "response_format": {
      "type": "json_object"
    }
  }
}
